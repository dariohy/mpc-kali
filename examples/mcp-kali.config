# Default MCP Kali configuration template.
#
# The installer renders the @...@ paths for either a user or system installation,
# then writes a ready-to-run mcp-kali.config. It contains no secrets.
# Existing shell variables override this file; command-line flags override both.

# RUST_LOG controls tracing verbosity: error, warn, info, debug, trace.
# This filters server JSONL/stdout logs and bridge stderr diagnostics. Debug and
# trace never log command arguments, bodies, credentials, webhook payloads, or
# captured job output.
RUST_LOG=mcp_kali=info,tower_http=info

# mcp-kali server
MCP_KALI_BIND=127.0.0.1:5000
MCP_KALI_HOME=@MCP_KALI_HOME@
MCP_KALI_STATE_DIR=@MCP_KALI_STATE_DIR@
MCP_KALI_LOG_DIR=@MCP_KALI_LOG_DIR@
MCP_KALI_JOB_ARCHIVE_DIR=@MCP_KALI_JOB_ARCHIVE_DIR@
MCP_KALI_JOB_ARCHIVE_AFTER_MINUTES=60
MCP_KALI_SYSTEM_DATA_DIR=@MCP_KALI_SYSTEM_DATA_DIR@
MCP_KALI_CONFIG_DIR=@MCP_KALI_CONFIG_DIR@
MCP_KALI_PRIVILEGE_ELEVATION=auto
MCP_KALI_MAX_CONCURRENCY=4
MCP_KALI_DEFAULT_TIMEOUT=432000
MCP_KALI_REVEAL_SENSITIVE_DATA=false
MCP_KALI_DISABLE_EXECUTE_COMMAND=false
MCP_KALI_ALLOW_REMOTE_BIND=false

# mcp-kali-bridge
MCP_KALI_BRIDGE_SERVER=http://127.0.0.1:5000
MCP_KALI_BRIDGE_ALLOW_INSECURE_HTTP=false
